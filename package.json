{
  "name": "@qubit-ltd/vite-plugin-vue-sfc-decorators",
  "version": "0.1.1",
  "description": "A small vite plugin to patch Vue SFC <script> to support decorators syntax.",
  "author": "Haixing Hu",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qubit-ltd/vite-plugin-vue-sfc-decorators.git"
  },
  "main": "dist/vite-plugin-vue-sfc-decorators.cjs",
  "module": "dist/vite-plugin-vue-sfc-decorators.mjs",
  "exports": {
    ".": {
      "require": "./dist/vite-plugin-vue-sfc-decorators.cjs",
      "import": "./dist/vite-plugin-vue-sfc-decorators.mjs"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "clean": "rm -rvf dist",
    "build": "node esbuild.mjs",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "lint": "eslint ./src",
    "deploy": "npm run lint && npm run build && npm publish --registry='https://registry.npmjs.org/' --access public"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@qubit-ltd/eslint-config": "^2.0.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.35.0",
    "eslint-plugin-import": "^2.32.0",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^10.4.0"
  },
  "packageManager": "yarn@4.12.0"
}
