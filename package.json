{
  "name": "@qubit-ltd/vite-plugin-vue-sfc-decorators",
  "version": "0.1.0",
  "description": "A small vite plugin to patch Vue SFC <script> to support decorators syntax.",
  "author": "Haixing Hu",
  "license": "Apache-2.0",
  "main": "dist/vite-plugin-vue-sfc-decorators.cjs",
  "module": "dist/vite-plugin-vue-sfc-decorators.mjs",
  "exports": {
    ".": {
      "require": "./dist/vite-plugin-vue-sfc-decorators.cjs",
      "import": "./dist/vite-plugin-vue-sfc-decorators.mjs"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "clean": "rm -rvf dist",
    "build": "node esbuild.mjs",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "lint": "eslint ./src",
    "deploy": "npm run lint && npm run build && npm publish --registry='https://registry.npmjs.org/' --access public"
  },
  "devDependencies": {
    "@qubit-ltd/eslint-config": "^1.3.4",
    "esbuild": "^0.24.0",
    "eslint": "^8.51.0",
    "eslint-plugin-import": "^2.28.1",
    "vitest": "^1.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
